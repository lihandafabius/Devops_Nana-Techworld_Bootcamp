def gv

pipeline {
    agent any
    tools {
        maven 'maven-9'
    }

    stages {
        stage('init'){
            steps {
                script {
                    echo 'Initializing the pipeline...'
                    gv = load 'jenkins/java-maven-app/script.groovy'
                }
            }
        }
        stage('Build jar') {
            steps {
                script {
                    gv.buildApp()
                }
            }
        }
        stage('Build docker image') {
            steps {
                script {
                    gv.buildDockerImage()
                }    
            }
        }
        stage('Deploy') {
            steps {
                script {
                    gv.deployApp()
                }
            }
        }
    }
}

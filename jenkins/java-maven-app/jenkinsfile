pipeline {
    agent any
    stages {
        stage('test') {
            steps {
                script {
                    echo 'Testing the application...'
                    echo "Running tests on branch: ${BRANCH_NAME}"
                    echo 'test successful'
                }
            }
        }
        stage('Build') {
            when {
                expression {
                    BRANCH_NAME == 'main'
                }
            }
            steps {
                script {
                    echo 'Building the application...'
                    echo 'test succesful'
                }
            }
        }

        stage('Deploy') {
            when {
                expression {
                    BRANCH_NAME == 'main'
                }
            }
            steps {
                script {
                    echo 'Deploying the application...'

                }
            }
        }
    }
}

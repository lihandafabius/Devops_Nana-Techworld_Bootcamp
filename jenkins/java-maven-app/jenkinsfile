#!/user/bin/env groovy

library identifier: 'jankins-shared-library@main', retriever: modernSCM(
        [$class: 'GITSCMSource',
        remote: 'https://gitlab.com/lihandafabius/jenkins-shared-library.git',
        credentialsId: 'gitlab-credentials'])

def gv

pipeline {
    agent any
    tools {
        maven 'maven-9'
    }

    stages {
        stage('init'){
            steps {
                script {
                    echo 'Initializing the pipeline...'
                    gv = load 'jenkins/java-maven-app/script.groovy'
                }
            }
        }
        stage('Build jar') {
            steps {
                script {
                    buildJar()
                }
            }
        }
        stage('Build and push docker image') {
            steps {
                script {
                    buildImage 'lihanda/demo-app:5.0'
                    dockerLogin()
                    dockerPush 'lihanda/demo-app:5.0'
                }    
            }
        }
        stage('Deploy') {
            steps {
                script {
                    gv.deployApp()
                }
            }
        }
    }
}

#!/usr/bin/env

@Library('Jenkins-shared-library')_

pipeline {
    agent any
    tools {
        nodejs 'node'
    }

    stages {
        stage('Check commit message') {
            steps {
                script {
                    commitCheck()
                }
            }
        }
        stage('Increment app version') {
            steps {
             script {
                echo 'Incrementing app version'
                sh 'cd jenkins-exercises/app && npm version minor --no-git-tag-version'

                def packageJson = readJSON file: 'jenkins-exercises/app/package.json'
                def version = packageJson.version

                env.IMAGE_NAME = "${version}-${BUILD_NUMBER}"
             }
            }
        }
        stage('Test code') {
            steps {
                script {
                    echo 'Running test'
                    sh 'cd jenkins-exercises/app && npm install && npm run test'
                }
            }
        }
        stage('Build docker image') {
            steps {
                script {
                    buildDockerImage()
                }
            }
        }
        stage('Deploy') {
            steps {
                script {
                    echo 'Deploying the application ..'
                }
            }
        }
        stage('Commit version update') {
            steps {
                script {

                    withCredentials([usernamePassword(
                        credentialsId: 'github-credentials',
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                    )]) {

                        sh '''
                            git config --global user.email "jenkins@example.com"
                            git config --global user.name "jenkins"

                            git remote set-url origin https://${USER}:${PASS}@github.com/lihandafabius/Devops_Nana-Techworld_Bootcamp.git

                            git add .
                            git commit -m "ci: version bump [skip ci]" || true

                            git pull --rebase origin main

                            git push origin HEAD:main
                        '''
                    }
                }
            }
        }
    }

}